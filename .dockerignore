# Repo-root .dockerignore — applies to BOTH agent images (they build from the
# repo root so they can copy agents_shared/).

# Node / Next site (irrelevant to Python images, large)
node_modules
.next
out
.vercel
.turbo
build
dist

# Python venvs and caches
**/venv
**/.venv
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache

# Secrets / local env
.env
.env.local
.env.*

# VCS + tooling
.git
.gitignore
.cursor
.claude
.agents

# Misc
*.log
.DS_Store
playground
scratch
logo-samples

# Voice agent leftovers (the chat agent is now stateless — Supabase only).
voice_agent/transcripts
voice_agent/__pycache__
voice_agent/venv
chatagent/__pycache__
chatagent/venv

# Files only used by the Next.js site
app
components
contents
lib
public
styles
utils
middleware.ts
next.config.mjs
next-env.d.ts
package.json
pnpm-lock.yaml
postcss.config.mjs
tsconfig.json
components.json
