# DigiiMark Voice Agent — .gitignore

# Environment secrets — NEVER commit these
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
ENV/
.env/

# RAG vector store (auto-generated — re-built from knowledge_base/ on startup)
rag/vector_store.faiss
rag/vector_metadata.json

# Transcripts (keep locally, don't push to shared repos)
transcripts/*.md
transcripts/calls_log.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
